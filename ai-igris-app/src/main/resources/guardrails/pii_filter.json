{
  "name": "pii_filter",
  "patterns": [
    {
      "id": "PII-001",
      "name": "SSN",
      "regex": "\\b\\d{3}-\\d{2}-\\d{4}\\b"
    },
    {
      "id": "PII-002",
      "name": "Email",
      "regex": "[\\w.-]+@[\\w.-]+\\.\\w+"
    },
    {
      "id": "PII-003",
      "name": "Phone",
      "regex": "[\\+]?[\\d\\s\\-\\(\\)]{10,}"
    },
    {
      "id": "PII-004",
      "name": "CreditCard",
      "regex": "\\b\\d{4}[\\s-]?\\d{4}[\\s-]?\\d{4}[\\s-]?\\d{4}\\b"
    },
    {
      "id": "PII-005",
      "name": "Aadhaar",
      "regex": "\\b\\d{4}\\s?\\d{4}\\s?\\d{4}\\b"
    }
  ],
  "violationMessage": "Input contains PII data."
}
